+function normalizeQuestion(s: string): string {
+  return s
+    .toLowerCase()
+    .replace(/[\s.,?!()'"‘’“”~`*\-_:;…]/g, '');
+}
+
+function bigrams(s: string): Set<string> {
+  const out = new Set<string>();
+  if (s.length === 0) return out;
+  if (s.length === 1) {
+    out.add(s);
+    return out;
+  }
+  for (let i = 0; i < s.length - 1; i++) out.add(s.slice(i, i + 2));
+  return out;
