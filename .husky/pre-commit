# PROJECT.md §3.5 — block secrets, sanity-check locale JSON, run lint-staged.

set -e

staged_env=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)\.env($|\.)' | grep -vE '(^|/)\.env[^/]*\.example$' || true)
if [ -n "$staged_env" ]; then
  echo "✗ Refusing to commit .env files (PROJECT.md §3.5 / §6):"
  echo "$staged_env" | sed 's/^/    /'
  echo "  Unstage: git restore --staged <path>  (and add to .gitignore if missing)"
  exit 1
fi

staged_json=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^messages/.*\.json$' || true)
if [ -n "$staged_json" ]; then
  for f in $staged_json; do
    if ! node -e "JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'))" "$f" 2>/tmp/husky-json-err; then
      echo "✗ Invalid JSON: $f"
      cat /tmp/husky-json-err
      exit 1
    fi
  done
fi

if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --no-banner --redact 2>/tmp/husky-gitleaks-err; then
    echo "✗ gitleaks: secret-looking pattern in staged diff (PROJECT.md §6 / §3.5)"
    cat /tmp/husky-gitleaks-err
    echo "  Remove the value, unstage, and re-stage."
    echo "  (Add an allowlist entry to .gitleaks.toml if this is a false positive.)"
    exit 1
  fi
fi

# Reject new supabase/migrations/*.sql files without a 14-digit timestamp
# prefix (PROJECT.md §3.8 / §7.9). 4-digit-prefix legacy files are
# grandfathered — only newly-added files trigger this guard.
bash scripts/check-migration-naming.sh

pnpm exec lint-staged
