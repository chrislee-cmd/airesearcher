# ────────────────────────────────────────────────────────────────────
# .env.local.example — local development env keys.
#
# 실제 secret 은 .env.local (gitignored) 에 두세요. 이 파일은 placeholder.
# 새 secret 을 추가하면 (1) src/env.ts 의 schema 에 등록하고 (2) Vercel 의
# production / preview / development 환경 모두에 등록해야 합니다 (PROJECT.md §8).
#
# 모든 env 사용은 `src/env.ts` 의 typed `env` 로 통합 (PR-SEC21).
# 직접 `process.env.X` 사용 금지 — `import { env } from '@/env'` 후 `env.X`.
# ────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# Required (prod build 실패 시 missing). dev 에서도 가능한 한 채우세요.
# ════════════════════════════════════════════════════════════════════

# Supabase — 모든 DB / Auth 접근. SERVICE_ROLE 은 server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron auth (PR-SEC5, PR-SEC21). cron/retention + translate/cleanup 가
# Bearer <CRON_SECRET> 헤더로만 통과. dev 에서도 설정 권장 — 미설정 시
# 위 cron 라우트는 401 을 던집니다 (이전엔 fail-open).
CRON_SECRET=

# Rate limit — Upstash Redis (PR-SEC4 / SEC-003 / SEC-019 / SEC-21 / SEC-4b).
# Vercel 마켓플레이스 → Upstash 로 자동 주입. 현재 optional (미설정 시
# rate-limit 이 fail-open 으로 통과 + warn 1회). Upstash 추가 후 SEC-4c
# 에서 다시 required 로 복원.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM providers — 모든 분석/생성 endpoint.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Deepgram — 전사 메인 엔진.
DEEPGRAM_API_KEY=
DEEPGRAM_WEBHOOK_SECRET=

# Gmail SMTP — 인보이스/inquiry/recruiting 메일 발송.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ════════════════════════════════════════════════════════════════════
# Optional — 미설정 시 해당 피처가 graceful degrade (사용 시점에서 503/skip).
# ════════════════════════════════════════════════════════════════════

# ElevenLabs — 전사 대체 엔진.
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# TwelveLabs — 영상 분석.
TWELVELABS_API_KEY=
TWELVELABS_ANALYZE_INDEX_ID=

# LiveKit — 동시통역 룸.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Lemon Squeezy — 결제. VARIANT_* 는 bundle 별 product variant id.
# 단일 store (레거시) — KRW + USD 분리 store 가 미설정이면 fallback 으로
# 양 통화 모두 이 store 로 라우팅됩니다 (KRW 로 취급).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_TEAM=
LEMONSQUEEZY_VARIANT_STUDIO=
LEMONSQUEEZY_VARIANT_ENTERPRISE=

# Dual-payout 분리 store. KRW = 국내 KRW 계좌 (하나은행) · USD = 외환 계좌.
# 한 쪽만 등록해도 그 통화는 분리, 미등록 통화는 단일 store 로 fallback.
LEMONSQUEEZY_STORE_ID_KRW=
LEMONSQUEEZY_WEBHOOK_SECRET_KRW=
LEMONSQUEEZY_VARIANT_STARTER_KRW=
LEMONSQUEEZY_VARIANT_TEAM_KRW=
LEMONSQUEEZY_VARIANT_STUDIO_KRW=
LEMONSQUEEZY_VARIANT_ENTERPRISE_KRW=
LEMONSQUEEZY_STORE_ID_USD=
LEMONSQUEEZY_WEBHOOK_SECRET_USD=
LEMONSQUEEZY_VARIANT_STARTER_USD=
LEMONSQUEEZY_VARIANT_TEAM_USD=
LEMONSQUEEZY_VARIANT_STUDIO_USD=
LEMONSQUEEZY_VARIANT_ENTERPRISE_USD=

# Google OAuth — Google 로그인.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Admin proxy — recruiting publish 가 모든 사용자 공통으로 이 계정의
# Drive 에 발행하도록 강제. 두 값이 모두 채워지면 admin proxy 모드 활성.
# 한 쪽이라도 비면 legacy 사용자별 OAuth 흐름으로 fallback.
GOOGLE_ADMIN_REFRESH_TOKEN=
GOOGLE_ADMIN_EMAIL=

# Desk research crawlers.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_REST_API_KEY=
YOUTUBE_API_KEY=

# Autocontents (PR-N3) — Notion 배포 토큰. PR-N1/N2 단계에서는 사용 안 함.
NOTION_API_TOKEN=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# Autocontents (PR-N3) — WordPress 배포. 인증 정책 (per-org credential storage
# 등) 은 PR-N3 에서 결정. 일단 placeholder 만.
WORDPRESS_API_URL=

# Admin dashboard 외부 provider 조회.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ANTHROPIC_ADMIN_KEY=
OPENAI_ADMIN_KEY=
SUPABASE_ACCESS_TOKEN=

# 인보이스 표시용 은행 정보.
BILLING_BANK_NAME=
BILLING_ACCOUNT_NUMBER=
BILLING_ACCOUNT_HOLDER=

# 메일 수신처 (미설정 시 schema default = chris.lee@meteor-research.com).
INQUIRY_TO_EMAIL=
QUOTE_TO_EMAIL=

# 모델 오버라이드 (미설정 시 schema default).
OPENAI_REALTIME_MODEL=
OPENAI_TRANSCRIPTION_MODEL=

# LLM 제로 보존 토글. 'false' 로 명시할 때만 비활성 (default = 'true').
LLM_ZERO_RETENTION=

# Client-only optional.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_TRANSLATE_VIEWER_HOST=
# PostHog product analytics. Project API key (phc_...) + ingest host.
# Host defaults to https://us.i.posthog.com when unset (use eu.i.posthog.com for EU).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
