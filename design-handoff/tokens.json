{
  "_meta": {
    "product": "Research-Canvas (ai-researcher)",
    "purpose": "Design contract — the token vocabulary Claude Design outputs against. Use the `class` (Tailwind utility) in .dc.html; never raw hex.",
    "source": "origin/main src/app/globals.css (@theme + [data-theme=pop] raw). SSOT = globals.css; this is a snapshot export.",
    "theme": "pop (production, canvas-locked)",
    "extracted": "2026-07-20",
    "rule": "Existing token → use its `class`. Intentional new value → label `proposed-token:<name>` (see CONTEXT-PACK.md §5), do NOT hardcode."
  },
  "color": {
    "accent": {
      "amore":      { "class": "amore",      "value": "#ff5c8a", "role": "PRIMARY brand/action accent — CTA, active, selection, focus (border-amore), live edge" },
      "amore-soft": { "class": "amore-soft", "value": "#ff96b6", "role": "muted accent" },
      "amore-bg":   { "class": "amore-bg",   "value": "#ffe1eb", "role": "accent background tint" },
      "_purple_note": "raw-accent-purple #a06fda ('bento amore', secondary — logo/eyebrow) is NOT exposed as a @theme utility. Do not use as bg-*/text-* class; it's raw-layer only."
    },
    "text": {
      "ink":       { "class": "ink",       "value": "#1d1b20", "role": "primary text" },
      "ink-2":     { "class": "ink-2",     "value": "#2a262f", "role": "heading / secondary" },
      "mute":      { "class": "mute",      "value": "#5b5965", "role": "body mute / helper" },
      "mute-soft": { "class": "mute-soft", "value": "#8a8693", "role": "caption / very mute — WCAG AA borderline, avoid on white for body" }
    },
    "surface": {
      "paper":      { "class": "paper",      "value": "#ffffff", "role": "card surface" },
      "paper-soft": { "class": "paper-soft", "value": "#f7f7f5", "role": "elevated / input bg" },
      "_surface-banner": { "value": "#ffd53d", "role": "widget header default (yellow banner) — via --surface-banner / widget-header-bg-default, not a color-* utility" },
      "_surface-accent": { "value": "#fffce1", "role": "sidebar/canvas bg (yellow) — via --surface-accent-bg" }
    },
    "line": {
      "line":      { "class": "line",      "value": "rgba(29,27,32,0.10)", "role": "regular border / divider" },
      "line-soft": { "class": "line-soft", "value": "rgba(29,27,32,0.06)", "role": "subtle divider" },
      "_border-strong": { "value": "#000000", "role": "heavy black outline (Memphis) — via --border-strong / border-ink; card=2.5-3px" }
    },
    "signal": {
      "success":      { "class": "success",      "value": "#16a34a", "role": "success / done — SEMANTIC signal, not a brand color" },
      "warning":      { "class": "warning",      "value": "#fb923c", "role": "warning / destructive" },
      "warning-bg":   { "class": "warning-bg",   "value": "#fff1e6", "role": "warning bg tint" },
      "warning-line": { "class": "warning-line", "value": "#ffd9bf", "role": "warning border" }
    },
    "pastel": {
      "lav":   { "class": "lav",   "value": "#e7defe", "role": "widget header / highlight — glyph ◇" },
      "peach": { "class": "peach", "value": "#ffd9c9", "role": "widget header — glyph ◆" },
      "mint":  { "class": "mint",  "value": "#cdebd9", "role": "widget header (Interpreter accent) — glyph ◉" },
      "sun":   { "class": "sun",   "value": "#fff1b6", "role": "widget header / default highlighter — glyph ★" },
      "sky":   { "class": "sky",   "value": "#cfe6ff", "role": "widget header (Probing accent) — glyph ◐" },
      "rose":  { "class": "rose",  "value": "#ffd0e2", "role": "widget header — glyph ✦" }
    },
    "chart": {
      "am-accent": { "class": "am-accent", "value": "#fb923c", "role": "AM chart series (data-viz only)" },
      "pm-accent": { "class": "pm-accent", "value": "#6c7aff", "role": "PM chart series (data-viz only)" }
    }
  },
  "radius": {
    "2xs":  { "class": "rounded-2xs",  "value": "2px" },
    "xs":   { "class": "rounded-xs",   "value": "4px" },
    "sm":   { "class": "rounded-sm",   "value": "14px", "role": "DEFAULT — card/button/input/modal" },
    "md":   { "class": "rounded-md",   "value": "24px" },
    "pill": { "class": "rounded-pill", "value": "999px", "role": "pills / cta buttons" }
  },
  "border_width": {
    "_note": "raw layer, applied via utilities like border-[2.5px] or component tokens",
    "hairline": "1px",
    "medium":   "2px  (button)",
    "strong":   "2.5px (card)",
    "heavy":    "3px  (canvas card)"
  },
  "shadow": {
    "_note": "Memphis hard offset, blur ALWAYS 0. Use shadow-memphis-* utilities; never shadow-[..].",
    "memphis-2xs": { "class": "shadow-memphis-2xs", "value": "1px 1px 0 #000" },
    "memphis-xs":  { "class": "shadow-memphis-xs",  "value": "1.5px 1.5px 0 #000" },
    "memphis-sm":  { "class": "shadow-memphis-sm",  "value": "2px 2px 0 #000", "role": "button" },
    "memphis-md":  { "class": "shadow-memphis-md",  "value": "3px 3px 0 #000", "role": "card / default" },
    "memphis-lg":  { "class": "shadow-memphis-lg",  "value": "4px 4px 0 #000" },
    "memphis-2xl": { "class": "shadow-memphis-2xl", "value": "8px 8px 0 var(--color-ink)" },
    "memphis-md-amore":   { "class": "shadow-memphis-md-amore",   "value": "3px 3px 0 #ff5c8a" },
    "memphis-md-warning": { "class": "shadow-memphis-md-warning", "value": "3px 3px 0 #fb923c" },
    "bento": { "class": "shadow-bento", "value": "0 1px 2px / 0 8px 24px rgba (soft — modal/editorial only)" }
  },
  "type_scale": {
    "_note": "font-size utilities text-*; small scale (px). Canvas display overrides h1-3 to 26-32/800/-0.02em.",
    "xs":      { "class": "text-xs",      "value": "10px" },
    "xs-soft": { "class": "text-xs-soft", "value": "10.5px", "role": "amore-soft eyebrow" },
    "sm":      { "class": "text-sm",      "value": "11.5px" },
    "md":      { "class": "text-md",      "value": "12.5px", "role": "default body" },
    "lg":      { "class": "text-lg",      "value": "13px" },
    "xl":      { "class": "text-xl",      "value": "15px" },
    "2xl":     { "class": "text-2xl",     "value": "18px" },
    "3xl":     { "class": "text-3xl",     "value": "22px" },
    "display": { "class": "text-display", "value": "32px" }
  },
  "font": {
    "sans": { "class": "font-sans", "value": "Pretendard Variable, Pretendard, Inter, Apple SD Gothic Neo, system-ui", "role": "body/UI default" },
    "hand": { "class": "font-hand", "value": "Caveat, cursive", "role": "handwriting accent (rare)" },
    "outfit": { "class": "font-[var(--font-outfit)]", "value": "Outfit 600/700/800", "role": "display/heading — canvas & app layouts ONLY, not a global @theme token; scoped var" },
    "_no_mono_default": "Production body is NOT monospace. Do not default to mono/Archivo/Courier.",
    "_logo_only": "Poppins Bold — logo wordmark SVG only, never in UI."
  },
  "motion": {
    "_note": "duration/easing tokens; never hardcode ms. utilities: .fade-in-up .pop-in .shake .stagger .press-scale",
    "dur-fast": { "var": "--dur-fast", "value": "120ms", "role": "press/hover" },
    "dur":      { "var": "--dur",      "value": "180ms", "role": "default transition" },
    "dur-slow": { "var": "--dur-slow", "value": "260ms", "role": "entrance" },
    "ease-out":        { "var": "--ease-out",        "value": "cubic-bezier(0.22,1,0.36,1)" },
    "ease-emphasized": { "var": "--ease-emphasized", "value": "cubic-bezier(0.34,1.4,0.64,1)", "role": "overshoot/bounce" },
    "motion-rise": { "var": "--motion-rise", "value": "6px" }
  },
  "widget_accent": {
    "_note": "per-widget canvas header color — sets identity on canvas. Do NOT unify to one color without a brand decision.",
    "probing": "sky (◐)",
    "translate": "mint (◉)",
    "available": ["default(yellow banner)", "sky", "peach", "mint", "lav", "sun", "rose"]
  },
  "iconography": {
    "library": "NONE (no lucide/heroicons)",
    "widget_glyphs": { "sky": "◐", "peach": "◆", "mint": "◉", "lav": "◇", "sun": "★", "rose": "✦" },
    "note": "unicode glyphs + inline SVG brand marks. Emoji used in copy."
  }
}
