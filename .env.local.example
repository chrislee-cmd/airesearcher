# ────────────────────────────────────────────────────────────────────
# .env.local.example — local development env keys.
#
# 실제 secret 은 .env.local (gitignored) 에 두세요. 이 파일은 placeholder.
# 새 secret 을 추가하면 Vercel 의 production / preview / development
# 환경 모두에 등록해야 합니다 (PROJECT.md §8).
# ────────────────────────────────────────────────────────────────────

# Rate limit — Upstash Redis (PR-SEC4 / SEC-003 / SEC-019).
# Add via Vercel 마켓플레이스 → Upstash. 미설정 시 fail open (warn only)
# 이라 dev / preview 는 동작은 하지만, production 에 반드시 등록.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Autocontents (PR-N3) — Notion 배포 토큰. PR-N1/N2 단계에서는 사용 안 함.
NOTION_API_TOKEN=

# Autocontents (PR-N3) — WordPress 배포. 인증 정책 (per-org credential storage
# 등) 은 PR-N3 에서 결정. 일단 placeholder 만.
WORDPRESS_API_URL=
WORDPRESS_API_USER=
WORDPRESS_API_PASSWORD=
