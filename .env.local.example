# ────────────────────────────────────────────────────────────────────
# .env.local.example — local development env keys.
#
# 실제 secret 은 .env.local (gitignored) 에 두세요. 이 파일은 placeholder.
# 새 secret 을 추가하면 (1) src/env.ts 의 schema 에 등록하고 (2) Vercel 의
# production / preview / development 환경 모두에 등록해야 합니다 (PROJECT.md §8).
#
# 모든 env 사용은 `src/env.ts` 의 typed `env` 로 통합 (PR-SEC21).
# 직접 `process.env.X` 사용 금지 — `import { env } from '@/env'` 후 `env.X`.
# ────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# Required (prod build 실패 시 missing). dev 에서도 가능한 한 채우세요.
# ════════════════════════════════════════════════════════════════════

# Supabase — 모든 DB / Auth 접근. SERVICE_ROLE 은 server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron auth (PR-SEC5, PR-SEC21). cron/retention + translate/cleanup 가
# Bearer <CRON_SECRET> 헤더로만 통과. dev 에서도 설정 권장 — 미설정 시
# 위 cron 라우트는 401 을 던집니다 (이전엔 fail-open).
CRON_SECRET=

# Rate limit — Upstash Redis (PR-SEC4 / SEC-003 / SEC-019 / SEC-21 / SEC-4b).
# Vercel 마켓플레이스 → Upstash 연결 시 KV_REST_API_* 이름으로 자동 주입.
# REQUIRED (fail-closed): 미설정 시 빌드/기동 실패. rate-limit 이 모든 LLM/STT
# 라우트의 비용 남용 캡을 강제하므로 조용히 비활성화되면 안 됨.
# prod/preview/dev 3환경 모두 등록 필수.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# LLM providers — 모든 분석/생성 endpoint.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Deepgram — 전사 메인 엔진.
DEEPGRAM_API_KEY=
DEEPGRAM_WEBHOOK_SECRET=

# Gmail SMTP — 인보이스/inquiry/recruiting 메일 발송.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ════════════════════════════════════════════════════════════════════
# Optional — 미설정 시 해당 피처가 graceful degrade (사용 시점에서 503/skip).
# ════════════════════════════════════════════════════════════════════

# ElevenLabs — 전사 대체 엔진.
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# TwelveLabs — 영상 분석.
TWELVELABS_API_KEY=
TWELVELABS_ANALYZE_INDEX_ID=

# LiveKit — 동시통역 룸.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Lemon Squeezy — 결제. VARIANT_* 는 bundle 별 product variant id.
# 단일 store (레거시) — KRW + USD 분리 store 가 미설정이면 fallback 으로
# 양 통화 모두 이 store 로 라우팅됩니다 (KRW 로 취급).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_TEAM=
LEMONSQUEEZY_VARIANT_STUDIO=
LEMONSQUEEZY_VARIANT_ENTERPRISE=

# Dual-payout 분리 store. KRW = 국내 KRW 계좌 (하나은행) · USD = 외환 계좌.
# 한 쪽만 등록해도 그 통화는 분리, 미등록 통화는 단일 store 로 fallback.
LEMONSQUEEZY_STORE_ID_KRW=
LEMONSQUEEZY_WEBHOOK_SECRET_KRW=
LEMONSQUEEZY_VARIANT_STARTER_KRW=
LEMONSQUEEZY_VARIANT_TEAM_KRW=
LEMONSQUEEZY_VARIANT_STUDIO_KRW=
LEMONSQUEEZY_VARIANT_ENTERPRISE_KRW=
LEMONSQUEEZY_STORE_ID_USD=
LEMONSQUEEZY_WEBHOOK_SECRET_USD=
LEMONSQUEEZY_VARIANT_STARTER_USD=
LEMONSQUEEZY_VARIANT_TEAM_USD=
LEMONSQUEEZY_VARIANT_STUDIO_USD=
LEMONSQUEEZY_VARIANT_ENTERPRISE_USD=

# Google OAuth — Google 로그인.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Admin proxy — recruiting publish 가 모든 사용자 공통으로 이 계정의
# Drive 에 발행하도록 강제. 두 값이 모두 채워지면 admin proxy 모드 활성.
# 한 쪽이라도 비면 legacy 사용자별 OAuth 흐름으로 fallback.
GOOGLE_ADMIN_REFRESH_TOKEN=
GOOGLE_ADMIN_EMAIL=

# AES-256-GCM key for at-rest encryption of stored Google refresh_tokens.
# Generate with: openssl rand -base64 32  (32 bytes → 44-char base64)
# Required in every environment (build fails without it).
OAUTH_TOKEN_ENC_KEY=

# Desk research crawlers.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_REST_API_KEY=
YOUTUBE_API_KEY=
# Optional — raises Semantic Scholar rate limit. Works without a key.
SEMANTIC_SCHOLAR_API_KEY=
# Tavily web search (https://tavily.com) — 탑라인 drag-to-ask 의 "웹 검색" 모드.
# 없으면 웹 모드만 비활성(인터뷰 근거 모드는 정상 동작).
TAVILY_API_KEY=
# 한국은행 ECOS 경제통계 (무료 https://ecos.bok.or.kr/api/)
ECOS_API_KEY=
# KOSIS (통계청) — 국내 시장 통계 TAM/SAM. 무료 신청 https://kosis.kr/openapi/
KOSIS_API_KEY=

# Autocontents (PR-N3) — Notion 배포 토큰. PR-N1/N2 단계에서는 사용 안 함.
NOTION_API_TOKEN=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# Autocontents (PR-N3) — WordPress 배포. 인증 정책 (per-org credential storage
# 등) 은 PR-N3 에서 결정. 일단 placeholder 만.
WORDPRESS_API_URL=

# Admin dashboard 외부 provider 조회.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ANTHROPIC_ADMIN_KEY=
OPENAI_ADMIN_KEY=
SUPABASE_ACCESS_TOKEN=

# 인보이스 표시용 은행 정보.
BILLING_BANK_NAME=
BILLING_ACCOUNT_NUMBER=
BILLING_ACCOUNT_HOLDER=

# 메일 수신처 (미설정 시 schema default = chris.lee@meteor-research.com).
INQUIRY_TO_EMAIL=
QUOTE_TO_EMAIL=

# 모델 오버라이드 (미설정 시 schema default).
OPENAI_REALTIME_MODEL=
OPENAI_TRANSCRIPTION_MODEL=

# 동시통역 자체 TTS 고정 voice (미설정 시 alloy / gpt-4o-mini-tts).
TRANSLATE_TTS_VOICE=
TRANSLATE_TTS_MODEL=

# LLM 제로 보존 토글. 'false' 로 명시할 때만 비활성 (default = 'true').
LLM_ZERO_RETENTION=

# 동시접속 정원 게이트 cap. 살아있는 세션이 이 수를 넘으면 신규 진입은 대기열.
# 미설정 시 5 (안전밸브 — 나중에 상향). 3환경(prod/preview/dev) 모두 등록 권장.
CONCURRENCY_CAP=

# Client-only optional.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_TRANSLATE_VIEWER_HOST=
# 자체 TTS 고정 voice kill-switch. 'off' 로 두면 모델 native 오디오로 복귀 (default = 'on').
NEXT_PUBLIC_TRANSLATE_CUSTOM_TTS=
# PostHog product analytics. Project API key (phc_...) + ingest host.
# Host defaults to https://us.i.posthog.com when unset (use eu.i.posthog.com for EU).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# Server-only. PostHog dashboard "Share externally" embed URL, rendered as
# the iframe src on /admin/analytics (super-admin only). e.g.
# https://us.posthog.com/embedded/DASHBOARD_ID?...
POSTHOG_EMBED_URL=

# ────────────────────────────────────────────────────────────────────
# PR preview QA 하네스 (e2e/ — docs/QA_HARNESS.md). 앱 런타임과 무관하고
# QA 실행 시에만 필요. 아래 값은 로그/PR/commit 에 노출되지 않음
# (이메일 마스킹, 비밀번호 미로깅).
# ────────────────────────────────────────────────────────────────────
# 대상 preview 베이스 URL. 예: https://ai-researcher-git-<branch>.vercel.app
QA_PREVIEW_URL=
# QA 테스터 계정(#149). 로그인 필요한 표면 스모크에만 사용.
QA_TEST_EMAIL=
QA_TEST_PASSWORD=
# 진입 경로 locale prefix (기본 ko).
QA_LOCALE=
# spec 의 `## QA 스크립트` 를 컴파일한 JSON 파일 경로 (권장 입력).
QA_SCRIPT_PATH=
